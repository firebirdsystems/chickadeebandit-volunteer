{
  "id": "volunteer",
  "name": "Volunteer Sign-Up",
  "version": "1.0.0",
  "description": "SignUpGenius-style slot sheets for potlucks, classroom helpers, carpool coverage, or shift backfills. Members claim, swap, and release capacity-limited slots without overbooking.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["signup", "volunteer", "slots", "events", "slot-claims"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["capacity", "note", "event_date"],
  "row_policies": {
    "sheets": {
      "kind": "adult_writable"
    },
    "slots": {
      "kind": "adult_writable"
    },
    "slot_claims": {
      "kind": "endpoint_only",
      "read": "everyone"
    }
  },
  "slot_claims": {
    "slot_table": "slots",
    "capacity_column": "capacity",
    "slot_status_column": "status",
    "slot_open_values": ["open"],
    "claims_table": "slot_claims",
    "slot_fk_column": "slot_id",
    "member_column": "member_id",
    "created_at_column": "created_at",
    "one_claim_per_member": true,
    "allow_release": true,
    "allowed_columns": ["note"],
    "max_text_lengths": { "note": 200 }
  },
  "publishes": ["volunteer.sheet_created", "volunteer.slot_claimed"],
  "nav": { "label": "Volunteer" },
  "widget": { "label": "Volunteer", "size": "small" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🙋",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["open_slots", "signup_summary"]
  }
}
